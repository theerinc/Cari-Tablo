# PostgreSQL bağlantı adresi (uygulama runtime'ı bunu kullanır; Supabase'de pooled/pgbouncer adresi).
# Yerelde: `npx prisma dev` çalıştırıp verdiği bağlantı adresini kullanın.
# Production: Neon / Prisma Postgres / Supabase gibi hosted bir Postgres adresi.
DATABASE_URL="postgres://user:password@host:6543/dbname?pgbouncer=true"

# Prisma CLI (migrate/db push/seed) için doğrudan (pooler'sız) bağlantı adresi.
# Supabase kullanıyorsanız 6543 yerine 5432 portlu adresi buraya koyun.
# Yoksa DATABASE_URL kullanılır (yerel geliştirmede genelde gerekmez).
DIRECT_URL="postgres://user:password@host:5432/dbname"

# Auth.js oturum imzalama anahtarı. `openssl rand -base64 32` ile üretebilirsiniz.
AUTH_SECRET="change-me"

# İlk admin kullanıcı (yalnızca `npx prisma db seed` ile ilk kurulumda kullanılır)
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-me"
ADMIN_NAME="Yönetici"

# Vade kontrolü cron endpoint'ini (/api/cron/vade-kontrol) korumak için gizli anahtar
CRON_SECRET="change-me"
