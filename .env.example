# PostgreSQL bağlantı adresi.
# Yerelde: `npx prisma dev` çalıştırıp verdiği bağlantı adresini kullanın.
# Production: Neon / Prisma Postgres / Supabase gibi hosted bir Postgres adresi.
DATABASE_URL="postgres://user:password@host:5432/dbname"

# Auth.js oturum imzalama anahtarı. `openssl rand -base64 32` ile üretebilirsiniz.
AUTH_SECRET="change-me"

# İlk admin kullanıcı (yalnızca `npx prisma db seed` ile ilk kurulumda kullanılır)
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-me"
ADMIN_NAME="Yönetici"

# Vade kontrolü cron endpoint'ini (/api/cron/vade-kontrol) korumak için gizli anahtar
CRON_SECRET="change-me"
